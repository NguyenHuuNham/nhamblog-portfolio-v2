# Environment Variables — copy this to .env and fill in your values

# JWT Secret (change this to a strong random string in production!)
JWT_SECRET=nhamblog_super_secret_change_this_in_production

# Render PostgreSQL / production database
# Use the External Database URL on Vercel, or Internal Database URL on a Render Web Service.
DATABASE_URL=
DATABASE_SSL=true

# Vercel Blob Store (auto-created by Vercel when a Blob store is connected)
BLOB_READ_WRITE_TOKEN=

# Server port
PORT=3000
